# Server
PORT=3000
NODE_ENV=production

# Database
DB_HOST=your-database-host
DB_PORT=3306
DB_USER=your-database-user
DB_PASSWORD=your-database-password
DB_NAME=pos_qr_system

# JWT
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRATION=1h

# WooCommerce
WC_WEBHOOK_SECRET=replace-with-your-woocommerce-webhook-secret
WC_API_URL=https://your-domain.com/wp-json/wc/v3
WC_CONSUMER_KEY=ck_replace_with_your_consumer_key
WC_CONSUMER_SECRET=cs_replace_with_your_consumer_secret

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
EMAIL_FROM=your-email@example.com

# Backend public URL
BASE_URL=https://api.your-domain.com

# Allowed frontend/backend origins, separated by commas
CORS_ORIGINS=https://your-frontend-domain.com,https://api.your-domain.com

# Development-only email filter.
# In production, leave empty so all customers can receive tickets.
TEST_EMAILS=edgarmen159@gmail.com

# Minimum WooCommerce order creation date to process tickets.
# Set this to your production launch date/time.
# Example for Cancun time:
# ORDER_PROCESSING_START_DATE=2026-05-16T00:00:00-05:00
ORDER_PROCESSING_START_DATE=

# Optional email pool settings
SMTP_MAX_CONNECTIONS=3
SMTP_MAX_MESSAGES=100
